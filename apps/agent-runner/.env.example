# Copy to .env. Everything is OPTIONAL — with none set, the studio runs in Simulation.

# Groq (free tier): https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# MCP servers (JSON). Example: a free, no-key web-fetch server via uvx.
#   MCP_SERVERS=[{"command":"uvx","args":["mcp-server-fetch"]}]
MCP_SERVERS=

# Safety caps
MAX_STEPS_CEILING=12
GLOBAL_DAILY_RUNS=500
